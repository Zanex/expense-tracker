// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js — non modificare ────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Dominio applicativo ─────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  expenses      Expense[]
  categories    Category[]
  trips         Trip[]
  createdAt     DateTime   @default(now())
}

model Category {
  id        String    @id @default(cuid())
  name      String
  icon      String?
  color     String?
  userId    String
  budget    Decimal?  @db.Decimal(10, 2)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  description String
  date        DateTime
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ─── Ricorrenza ────────────────────────────────────────
  isRecurring        Boolean   @default(false)
  recurringFrequency String?   // "monthly" | "weekly" | "yearly"
  recurringEndDate   DateTime?
  recurringParentId  String?   // id della spesa "template" originale

  // ─── Viaggi ────────────────────────────────────────
  tripId  String?
  trip    Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([userId, date])           // performance dashboard query
  @@index([userId, isRecurring])    // performance processRecurring
  @@index([userId, tripId])
}

model Trip {
  id          String    @id @default(cuid())
  name        String
  destination String?
  startDate   DateTime
  endDate     DateTime?
  budget      Decimal?  @db.Decimal(10, 2)
  coverColor  String?   // colore hex es. "#6366f1"
  coverEmoji  String?   // emoji es. "🏖️"
  notes       String?   @db.Text

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses    Expense[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, startDate])
}
